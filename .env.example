# The hosted Landed API this proxy forwards to. Include the /api/v1 prefix.
# Point at production, or at your own Landed server.
LANDED_API_BASE=https://api.landed.jobs/api/v1

# Shared secret that authenticates this proxy to the Landed API.
# Must match the server's INTERNAL_SERVICE_SECRET.
LANDED_INTERNAL_SECRET=

# HTTP server
PORT=8090
CORS_ORIGINS=*

# Cheap first-line abuse guard (requests/min/IP). The real economic cap is the API's freemium meter.
RATE_LIMIT_PER_MIN=60
